---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Get all blog posts
const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Get all unique tags
const allTags = [...new Set(posts.flatMap(post => post.data.tags))].sort();
---

<Layout title="Blog - Digital Notes">
    <script>
        // Check for saved theme preference and apply it
        if (typeof window !== 'undefined') {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                document.documentElement.classList.add('dark-theme');
            }
        }
    </script>
    
    <div class="blog-page">
        <header class="blog-header">
            <div class="header-content">
                <h1>
                    <svg class="header-icon" width="32" height="32" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="m22,4v-1h-1v-1h-1v-1h-3v1h-1v1h-1v1h-1v1h-2v1h-3v1h-3v1h-1v2h-1v3h-1v3h-1v3h-1v3h1v1h3v-1h3v-1h3v-1h3v-1h2v-1h1v-3h1v-3h1v-2h1v-1h1v-1h1v-1h1v-3h-1Zm-6,8v3h-1v2h-1v1h-3v1h-3v1h-2v-1h1v-1h1v-1h1v-1h3v-3h-1v-1h-3v3h-1v1h-1v1h-1v1h-1v-2h1v-3h1v-3h1v-1h2v-1h3v-1h3"/>
                    </svg>
                    Digital Notes
                </h1>
                <p>My thoughts, experiences, and discoveries in the world of tech and creativity.</p>
                <a href="/" class="back-link">← Back to Home</a>
            </div>
        </header>
        
        <main class="blog-main">
            <div class="blog-container">
                <div class="blog-content">
                    <div class="blog-layout">
                        <!-- Main content -->
                        <div class="main-content">
                            <div class="search-section">
                                <input 
                                    type="text" 
                                    placeholder="Search notes..." 
                                    id="search-input"
                                    class="search-input"
                                />
                            </div>
                            
                            <div class="tags-section">
                                <h3>Tags</h3>
                                <div class="tag-buttons">
                                    {allTags.map(tag => (
                                        <button 
                                            class="tag-btn"
                                            data-tag={tag}
                                            type="button"
                                        >
                                            #{tag}
                                        </button>
                                    ))}
                                </div>
                                <button class="clear-btn" id="clear-filters" type="button">
                                    Clear filters
                                </button>
                            </div>
                            
                            <div class="content-header">
                                <h2>All Notes (<span id="post-count">{posts.length}</span>)</h2>
                            </div>
                            
                            <div class="posts-list" id="posts-list">
                                {posts.map(post => (
                                    <a 
                                        href={`/blog/${post.slug}`}
                                        class="post-card" 
                                        data-tags={post.data.tags.join(',')}
                                        data-title={post.data.title.toLowerCase()}
                                        data-excerpt={post.data.excerpt.toLowerCase()}
                                        aria-label="Read post: {post.data.title}"
                                    >
                                        <div class="post-header">
                                            <h3>{post.data.title}</h3>
                                            <span class="post-date">{post.data.date.toLocaleDateString()}</span>
                                        </div>
                                        <p class="post-excerpt">{post.data.excerpt}</p>
                                        <div class="post-tags">
                                            {post.data.tags.map(tag => (
                                                <span class="tag">#{tag}</span>
                                            ))}
                                        </div>
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</Layout>

<style>
    .blog-page {
        background-color: var(--bg-color);
        background-image: url('/images/ocean-wallpaper.webp');
        /* Fallback for browsers that don't support WebP */
        @supports not (background-image: url('/images/ocean-wallpaper.webp')) {
            background-image: url('/images/ocean-wallpaper-optimized.png');
        }
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        font-family: 'VT323', monospace;
        color: var(--font-color);
        padding-bottom: 100px;
        min-height: 100vh;
        transition: background-color 0.3s ease, color 0.3s ease;
        position: relative;
    }
    
    .blog-page::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0);
        transition: background 0.3s ease;
        pointer-events: none;
        z-index: 0;
    }
    
    :global(.dark-theme) .blog-page::before {
        background: rgba(0, 0, 0, 0.4);
    }
    
    .blog-header {
        background-color: rgba(var(--header-color-rgb), 0.95);
        border-bottom: 3px solid var(--border-color);
        padding: 12px 20px;
        box-shadow: 0 4px 8px var(--shadow-color);
        backdrop-filter: blur(2px);
        transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    
    .header-content {
        max-width: 1400px;
        margin: 0 auto;
        text-align: center;
    }
    
    .header-content h1 {
        font-size: 2em;
        margin: 0 0 6px 0;
        color: var(--font-color);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
        transition: color 0.3s ease, text-shadow 0.3s ease;
    }
    
    :global(.dark-theme) .header-content h1 {
        text-shadow: 1px 1px 2px rgba(255, 255, 255, 0.3);
    }
    
    .header-icon {
        fill: var(--font-color);
        filter: drop-shadow(2px 2px 0 var(--shadow-color));
    }
    
    .header-content p {
        font-size: 0.9em;
        margin: 0 0 10px 0;
        opacity: 0.8;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
        transition: text-shadow 0.3s ease;
    }
    
    :global(.dark-theme) .header-content p {
        text-shadow: 1px 1px 2px rgba(255, 255, 255, 0.2);
    }
    
    .back-link {
        display: inline-block;
        padding: 6px 14px;
        background-color: rgba(var(--surface-color-rgb), 0.95);
        border: 2px solid var(--border-color);
        border-radius: 6px;
        color: var(--font-color);
        text-decoration: none;
        font-family: 'VT323', monospace;
        font-size: 0.9em;
        transition: all 0.2s ease;
        backdrop-filter: blur(2px);
    }
    
    .back-link:hover {
        background-color: rgba(0, 0, 0, 0.9);
        color: var(--surface-color);
        transform: translateY(-2px);
    }
    
    .blog-main {
        padding: 20px 20px 40px 20px;
    }
    
    .blog-container {
        max-width: 1400px;
        margin: 0 auto;
    }
    
    .blog-content {
        background-color: rgba(var(--surface-color-rgb), 0.95);
        border: 3px solid var(--border-color);
        border-radius: 8px;
        padding: 20px;
        box-shadow: 5px 5px 0 var(--shadow-color);
        margin-bottom: 40px;
        backdrop-filter: blur(2px);
        transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    
    /* Layout */
    .blog-layout {
        display: block;
    }
    
    .search-section {
        margin-bottom: 20px;
    }
    
    .search-input {
        width: 100%;
        padding: 10px 12px;
        border: 2px solid var(--border-color);
        border-radius: 6px;
        background-color: var(--surface-color);
        color: var(--font-color);
        font-family: 'VT323', monospace;
        font-size: 1em;
        box-sizing: border-box;
        transition: border-color 0.3s ease, background-color 0.3s ease, color 0.3s ease;
    }
    
    .search-input:focus {
        outline: none;
        border-color: #007acc;
        box-shadow: 0 0 0 2px rgba(0, 122, 204, 0.2);
    }
    
    .tags-section {
        margin-bottom: 25px;
    }
    
    .tags-section h3 {
        color: var(--font-color);
        margin: 0 0 15px 0;
        font-size: 1.2em;
        transition: color 0.3s ease;
    }
    
    .tag-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 15px;
    }
    
    .tag-btn {
        padding: 6px 12px;
        border: 1px solid var(--border-color);
        border-radius: 4px;
        background-color: var(--surface-color);
        color: var(--font-color);
        font-family: 'VT323', monospace;
        font-size: 0.9em;
        cursor: pointer;
        transition: all 0.2s ease;
        white-space: nowrap;
    }
    
    .tag-btn:hover {
        background-color: var(--border-color);
        color: var(--surface-color);
    }
    
    .tag-btn.active {
        background-color: var(--border-color);
        color: var(--surface-color);
    }
    
    .clear-btn {
        padding: 8px 16px;
        border: 2px solid var(--border-color);
        border-radius: 4px;
        background-color: var(--surface-color);
        color: var(--font-color);
        font-family: 'VT323', monospace;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .clear-btn:hover {
        background-color: var(--border-color);
        color: var(--surface-color);
    }
    
    /* Main Stuff */
    .main-content {
        width: 100%;
    }
    
    .content-header {
        margin-bottom: 20px;
    }
    
    .content-header h2 {
        color: var(--font-color);
        margin: 0;
        font-size: 1.5em;
        transition: color 0.3s ease;
    }
    
    .posts-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    
    .post-card {
        background-color: var(--surface-color);
        border: 2px solid var(--border-color);
        border-radius: 8px;
        padding: 20px;
        transition: all 0.2s ease;
        position: relative;
        display: block;
        text-decoration: none;
        color: inherit;
    }
    
    .post-card:hover {
        transform: translateY(-2px);
        box-shadow: 3px 3px 0 var(--shadow-color);
        text-decoration: none;
        color: inherit;
    }
    
    .post-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 10px;
    }
    
    .post-header h3 {
        color: var(--font-color);
        margin: 0;
        flex: 1;
        font-size: 1.3em;
        transition: color 0.3s ease;
    }
    
    .post-date {
        color: #444;
        font-size: 0.9em;
        white-space: nowrap;
        margin-left: 10px;
    }
    
    .post-excerpt {
        color: var(--font-color);
        margin: 10px 0;
        line-height: 1.5;
        transition: color 0.3s ease;
    }
    
    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin: 15px 0;
    }
    
    .tag {
        background-color: var(--surface-color);
        border: 1px solid var(--border-color);
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 0.8em;
        color: var(--font-color);
    }
    

    
    /* Custom scrollbar for main content */
    .main-content::-webkit-scrollbar {
        width: 8px;
    }
    
    .main-content::-webkit-scrollbar-track {
        background: var(--surface-color);
        border-radius: 4px;
    }
    
    .main-content::-webkit-scrollbar-thumb {
        background: var(--border-color);
        border-radius: 4px;
    }
    
    .main-content::-webkit-scrollbar-thumb:hover {
        background: #666;
    }
    
    /* Mobile responsive adjustments */
    @media (max-width: 768px) {
        .blog-header {
            padding: 8px 15px;
        }
        
        .header-content h1 {
            font-size: 1.6em;
            margin: 0 0 4px 0;
        }
        
        .header-content p {
            font-size: 0.8em;
            margin: 0 0 8px 0;
        }
        
        .back-link {
            padding: 5px 12px;
            font-size: 0.8em;
        }
        
        .blog-main {
            padding: 15px 15px 40px 15px;
        }
        
        .blog-content {
            padding: 15px;
        }
        
        .search-input {
            font-size: 0.9em;
            padding: 8px 10px;
        }
        
        .tag-buttons {
            gap: 6px;
        }
        
        .tag-btn {
            font-size: 0.8em;
            padding: 4px 8px;
        }
        
        .post-card {
            padding: 15px;
        }
        
        .post-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 5px;
        }
        
        .post-date {
            margin-left: 0;
            font-size: 0.8em;
        }
        
        .post-header h3 {
            font-size: 1.1em;
        }
        
        .post-excerpt {
            font-size: 0.9em;
        }
        
        .tag {
            font-size: 0.7em;
        }
    }
</style>

<script>
    // Client-side filtering functionality
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('search-input') as HTMLInputElement;
        const tagButtons = document.querySelectorAll('.tag-btn') as NodeListOf<HTMLButtonElement>;
        const clearButton = document.getElementById('clear-filters') as HTMLButtonElement;
        const postCards = document.querySelectorAll('.post-card') as NodeListOf<HTMLElement>;
        const postCount = document.getElementById('post-count') as HTMLElement;
        
        let selectedTags: string[] = [];
        
        function filterPosts() {
            if (!searchInput || !postCount) return;
            
            const searchTerm = searchInput.value.toLowerCase();
            let visibleCount = 0;
            
            postCards.forEach(card => {
                const title = card.dataset.title || '';
                const excerpt = card.dataset.excerpt || '';
                const tags = (card.dataset.tags || '').split(',');
                
                const matchesSearch = !searchTerm || 
                    title.includes(searchTerm) || 
                    excerpt.includes(searchTerm) ||
                    tags.some(tag => tag.toLowerCase().includes(searchTerm));
                
                const matchesTags = selectedTags.length === 0 || 
                    selectedTags.every(tag => tags.includes(tag));
                
                if (matchesSearch && matchesTags) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });
            
            postCount.textContent = visibleCount.toString();
        }
        
        // Search functionality
        if (searchInput) {
            searchInput.addEventListener('input', filterPosts);
        }
        
        // Tag filtering
        tagButtons.forEach(button => {
            button.addEventListener('click', function(this: HTMLButtonElement) {
                const tag = this.dataset.tag || '';
                
                if (selectedTags.includes(tag)) {
                    selectedTags = selectedTags.filter(t => t !== tag);
                    this.classList.remove('active');
                } else {
                    selectedTags.push(tag);
                    this.classList.add('active');
                }
                
                filterPosts();
            });
        });
        
        // Clear filters
        if (clearButton) {
            clearButton.addEventListener('click', function() {
                if (searchInput) {
                    searchInput.value = '';
                }
                selectedTags = [];
                tagButtons.forEach(btn => btn.classList.remove('active'));
                filterPosts();
            });
        }
    });
</script> 